import random

def estimate_pi(num_points):
    inside_circle = 0

    for _ in range(num_points):
        x = random.random()
        y = random.random()

        if x*x + y*y <= 1:
            inside_circle += 1

    pi_estimate = 4 * inside_circle / num_points
    return pi_estimate


points = 1000000
pi = estimate_pi(points)

print("Estimated π:", pi)
